generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ENUMS
// ==========================================

enum Role {
  USER
  ADMIN
}

enum UpdateType {
  FEATURE
  BUGFIX
  ANNOUNCEMENT
  RELEASE
}

// ==========================================
// AUTH MODELS (NextAuth v5 / @auth/prisma-adapter)
// ==========================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  gender        String?
  brandColor    String?   @default("#FF4B72")
  role          Role      @default(USER)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts              Account[]
  sessions              Session[]
  forumPosts            ForumPost[]
  newsCards             NewsCard[]
  hubUpdates            HubUpdate[]
  communitiesCreated    Community[]
  nunuProfile           NunuProviderProfile?
  nunuLikes             NunuLike[]
  nunuComments          NunuComment[]
  nunuFollows           NunuFollow[]
  nunuReports           NunuReport[]
  nunuCommentLikes      NunuCommentLike[]
  receivedNotifications NunuNotification[]   @relation("ReceivedNotifications")
  sentNotifications     NunuNotification[]   @relation("SentNotifications")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// NEWS (Cards de notícia no hub)
// ==========================================

model NewsCard {
  id        String   @id @default(cuid())
  title     String
  summary   String
  content   String?  @db.Text
  imageUrl  String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id])
}

// ==========================================
// HUB UPDATES (Atualizações de apps/produtos)
// ==========================================

model HubUpdate {
  id          String     @id @default(cuid())
  appName     String
  version     String?
  title       String
  description String     @db.Text
  type        UpdateType @default(FEATURE)
  published   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id])
}

// ==========================================
// FORUM
// ==========================================

model ForumCategory {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?
  color       String?
  order       Int     @default(0)

  posts ForumPost[]
}

model ForumPost {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  imageUrl  String?
  published Boolean  @default(true)
  pinned    Boolean  @default(false)
  locked    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId   String
  author     User          @relation(fields: [authorId], references: [id])
  categoryId String
  category   ForumCategory @relation(fields: [categoryId], references: [id])
}

// ==========================================
// COMMUNITIES
// ==========================================

model Community {
  id             String   @id @default(cuid())
  name           String
  description    String   @db.Text
  type           String // "public" | "restricted"
  creatorPlan    String   @default("GRACE") // SimulatedPlan e.g. "GRACE", "FIEL", "APOSTOLO"
  memberCount    Int      @default(1)
  tags           String[]
  bannerGradient String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  creatorId String
  creator   User               @relation(fields: [creatorId], references: [id])
  channels  CommunityChannel[]
}

model CommunityChannel {
  id          String   @id @default(cuid())
  name        String
  description String   @db.Text
  isBot       Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  communityId String
  community   Community        @relation(fields: [communityId], references: [id], onDelete: Cascade)
  messages    ChannelMessage[]
}

model AgentInstruction {
  id        String   @id @default("default")
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChannelMessage {
  id         String   @id @default(cuid())
  content    String   @db.Text
  senderId   String? // Nullable for bot or system messages
  senderName String
  senderRole String // "Membro" | "Moderador" | "Bot" | "Staff"
  plan       String? // "Básico" | "Pro" | "Elite" | "Staff"
  avatarUrl  String?
  isAi       Boolean  @default(false)
  createdAt  DateTime @default(now())

  channelId String
  channel   CommunityChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

// ==========================================
// NUNU MARKETPLACE (Mobile App)
// ==========================================

model NunuCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  icon        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  providerProfiles NunuProviderProfile[] @relation("ProfileCategories")
}

model NunuProviderProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isProvider            Boolean  @default(false)
  requirementsCompleted Boolean  @default(false)
  bio                   String?  @db.Text
  contactPhone          String?
  state                 String?
  city                  String?
  latitude              Float?
  longitude             Float?
  rating                Float    @default(0.0)
  reviewCount           Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  categories NunuCategory[] @relation("ProfileCategories")

  services  NunuService[]
  posts     NunuPost[]
  followers NunuFollow[]  @relation("FollowTarget")
  following NunuFollow[]  @relation("FollowSource")
}

model NunuService {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  price       Float?
  imageUrl    String?
  region      String? // Ex: "SP - São Paulo"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  providerId String
  provider   NunuProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  posts NunuPost[] // Posts linked to this service
}

enum MediaType {
  VIDEO
  IMAGE
}

model NunuPost {
  id        String    @id @default(cuid())
  caption   String?   @db.Text
  mediaUrl  String
  mediaType MediaType @default(VIDEO)
  viewCount Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  authorId String
  author   NunuProviderProfile @relation(fields: [authorId], references: [id], onDelete: Cascade)

  serviceId String?
  service   NunuService? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  // Repost system
  originalPostId String?
  originalPost   NunuPost?  @relation("Reposts", fields: [originalPostId], references: [id], onDelete: Cascade)
  reposts        NunuPost[] @relation("Reposts")

  likes    NunuLike[]
  comments NunuComment[]
  reports  NunuReport[]
}

model NunuLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  postId String
  post   NunuPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model NunuComment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  postId String
  post   NunuPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  commentLikes NunuCommentLike[]
}

model NunuFollow {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // O usuário (comum ou prestador) que está seguindo
  followerUserId String
  followerUser   User   @relation(fields: [followerUserId], references: [id], onDelete: Cascade)

  // O prestador de serviço que está sendo seguido
  targetProviderId String
  targetProvider   NunuProviderProfile @relation("FollowTarget", fields: [targetProviderId], references: [id], onDelete: Cascade)

  // Relação redundante caso o prestador queira seguir de volta usando seu perfil (Opcional, mas útil)
  sourceProviderId String?
  sourceProvider   NunuProviderProfile? @relation("FollowSource", fields: [sourceProviderId], references: [id], onDelete: Cascade)

  @@unique([followerUserId, targetProviderId])
}

model NunuReport {
  id        String   @id @default(cuid())
  reason    String   @db.Text
  status    String   @default("PENDING") // PENDING, REVIEWED, RESOLVED
  createdAt DateTime @default(now())

  postId String
  post   NunuPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NunuCommentLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  commentId String
  comment   NunuComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
}

model NunuNotification {
  id        String   @id @default(cuid())
  type      String // MENTION, LIKE, FOLLOW
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  recipientUserId String
  recipient       User   @relation("ReceivedNotifications", fields: [recipientUserId], references: [id], onDelete: Cascade)

  actorUserId String?
  actor       User?   @relation("SentNotifications", fields: [actorUserId], references: [id], onDelete: Cascade)
}
